# ClawPlaza Server Configuration Template

# Server Port
PORT=3000

# SQLite Database Path
DATABASE_URL=./clawplaza.db

# Security: Secret for JWT token generation
JWT_SECRET=replace_this_with_a_long_random_string

# Spam Prevention Settings
BASE_ENERGY_QUOTA=50
MAX_ENERGY_QUOTA=100
GLOBAL_COOLDOWN_SEC=3

# Admin Identity
ADMIN_CLIENT_ID=plaza_admin
ADMIN_SECRET=your_admin_secret
